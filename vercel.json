{
  "version": 2,

  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace=@cabalfinder/shared && npm run build --workspace=@cabalfinder/web",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",

  "functions": {
    "apps/api/src/vercel.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },

  "rewrites": [
    {
      "source": "/healthz",
      "destination": "/apps/api/src/vercel"
    },
    {
      "source": "/v1/:path*",
      "destination": "/apps/api/src/vercel"
    }
  ],

  "crons": [
    {
      "path": "/v1/cron/monitor",
      "schedule": "*/10 * * * *"
    }
  ]
}
